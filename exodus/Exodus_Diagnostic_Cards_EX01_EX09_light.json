      "efficiency overriding human consequences",
      "decisions made without relational awareness",
      "language shifts from who to what",
      "compliance valued over recognition"
    ],
    "warning_signs": [
      "dehumanization in communication",
      "instrumental treatment of people",
      "lack of mutual presence",
      "structural blindness to dignity",
      "relational disconnect"
    ],
    "reflection_questions": [
      "are people treated as subjects or objects?",
      "what language reveals objectification?",
      "where is dignity compromised?",
      "is efficiency replacing humanity?",
      "what would a relational shift look like?"
    ],
    "safe_actions": [
      "restore subject-to-subject recognition",
      "adjust language to reflect dignity",
      "introduce relational awareness in decisions",
      "prioritize presence over function",
      "rebuild human connection"
    ]
  },
