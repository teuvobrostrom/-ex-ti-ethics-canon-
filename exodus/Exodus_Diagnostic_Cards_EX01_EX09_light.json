[
  {
    "id": "EX-00",
    "title": "Exit (Mental Liberation from Slavery)",
    "core_moral_threshold": "A system transition begins only when individuals are mentally liberated from internalized subjugation. Physical exit without cognitive release preserves the old system in latent form.",
    "trigger_patterns": [
      "continued identification with the oppressor after exit",
      "nostalgia for former system despite harm",
      "fear of autonomy overriding capacity for self-direction",
      "external freedom paired with internal dependency",
      "language of \"we cannot survive without them\""
    ],
    "warning_signs": [
      "desire to return to the prior system",
      "inability to make independent decisions",
      "replication of old hierarchies in new environments",
      "paralysis in absence of control structures",
      "collective anxiety replacing imposed order"
    ],
    "reflection_questions": [
      "has the system been exited physically but not mentally?",
      "where does dependency still define identity?",
      "what beliefs bind actors to the previous structure?",
      "is freedom experienced as threat or possibility?",
      "what remains of the internal Pharaoh?"
    ],
    "safe_actions": [
      "surface internalized dependency structures",
      "separate survival fear from actual conditions",
      "build minimal autonomous decision capacity",
      "expose residual loyalty to oppressive logic",
      "reinforce identity independent of prior system"
    ]
  },
  {
    "id": "EX-00B",
    "title": "Point of No Return (Irreversible Transition)",
    "core_moral_threshold": "A system transformation becomes real only when reversal is structurally or psychologically impossible. Without irreversibility, regression remains the dominant attractor.",
    "trigger_patterns": [
      "hesitation at decisive transition points",
      "preservation of fallback options to prior system",
      "dual alignment between old and new structures",
      "delayed commitment under uncertainty",
      "negotiation with the past instead of separation"
    ],
    "warning_signs": [
      "active consideration of returning",
      "partial disengagement from previous system",
      "reliance on legacy structures \"just in case\"",
      "fragmented identity across systems",
      "repeated backward-looking decisions"
    ],
    "reflection_questions": [
      "what still enables reversal?",
      "has a true break been made or only simulated?",
      "where are fallback paths still preserved?",
      "what would make return impossible?",
      "is commitment explicit or assumed?"
    ],
    "safe_actions": [
      "remove structural and psychological fallback paths",
      "define irreversible commitments",
      "align identity with forward trajectory",
      "document the break point explicitly",
      "reinforce continuity in the new direction"
    ]
  },
  {
